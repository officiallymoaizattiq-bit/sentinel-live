# MongoDB (Atlas connection string or local mongodb://localhost:27017)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sentinel

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ElevenLabs Conversational AI (https://elevenlabs.io/app/conversational-ai)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Only needed if dialing real phones via Twilio (leave blank for widget-only demo)
ELEVENLABS_PHONE_NUMBER_ID=

# Twilio — optional, leave blank to run in widget-only mode
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public URL (for Twilio webhooks; use ngrok URL in dev)
PUBLIC_BASE_URL=http://localhost:8000

# Dashboard auth passkeys
ADMIN_PASSKEY=a
PATIENT_PASSKEY=b

# Signing secrets — replace with long random values in production
SESSION_SECRET=change-me-in-production
DEVICE_TOKEN_SECRET=change-me-in-production

CALL_CADENCE_HOURS=12
DEMO_MODE=true
