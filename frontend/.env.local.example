# Where the UI (browser SSE + SSR fetch) should reach the backend.
# For local dev, the Next dev server runs at :3000 and proxies to :8000.
BACKEND_URL=http://localhost:8000

# Exposed to the browser — ElevenLabs agent ID for the embedded Convai widget.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Optional — the browser EventSource talks to the backend directly (bypasses
# Next's dev proxy because it buffers SSE). Defaults to http://localhost:8000.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
