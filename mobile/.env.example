# Backend base URL. LAN IP for same-wifi dev, ngrok for HTTPS, Fly/Render for deployed.
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# App version surfaced to backend as device_info.app_version (keep in sync with package.json).
EXPO_PUBLIC_APP_VERSION=0.1.0

# ElevenLabs Convai agent ID. Mirrors NEXT_PUBLIC_ELEVENLABS_AGENT_ID from frontend/.env.local
# so the mobile app can answer "Sentinel is calling you" prompts with the same agent the
# web /patient view uses. Without this set, the call panel falls back to a disabled state.
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=
