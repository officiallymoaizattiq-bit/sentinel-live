{
  "expo": {
    "name": "Sentinel",
    "slug": "sentinel-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sentinel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sentinel.mobile",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Sentinel reads your heart rate, blood oxygen, respiratory rate, and other vitals so your care team can spot signs of post-operative deterioration early.",
        "NSHealthUpdateUsageDescription": "Sentinel does not write to Health. This permission is required by the system but unused.",
        "NSMicrophoneUsageDescription": "Sentinel uses the microphone for voice check-in calls with your care team's AI assistant.",
        "NSCameraUsageDescription": "Sentinel uses the camera to scan the pairing QR code from your care team.",
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "voip",
          "audio"
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "package": "com.sentinel.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_RESPIRATORY_RATE",
        "android.permission.health.READ_BODY_TEMPERATURE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "sentinel"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Sentinel uses the camera to scan the pairing QR code from your care team."
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Sentinel reads your vitals to support post-op monitoring.",
          "healthUpdatePermission": "Sentinel does not write to Health."
        }
      ],
      "react-native-health-connect",
      "./plugins/with-health-connect-delegate.js",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "expo-asset",
      [
        "expo-notifications",
        {
          "androidMode": "default",
          "androidCollapsedTitle": "Sentinel"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
